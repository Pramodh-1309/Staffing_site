<?xml version="1.0" encoding="utf-8"?>
<!--
  AppSettings.config — Aivirtrix Staffing Platform
  IMPORTANT: Add this file to .gitignore before committing.
  Replace all REPLACE_WITH_* values before deploying to production.
-->
<appSettings>

  <!-- ── SMTP Email (Gmail App Password recommended) ── -->
  <add key="SmtpHost"       value="smtp.gmail.com"/>
  <add key="SmtpPort"       value="587"/>
  <add key="SmtpUser"       value="REPLACE_WITH_GMAIL_ADDRESS"/>
  <add key="SmtpPass"       value="REPLACE_WITH_APP_PASSWORD"/>
  <add key="SmtpFromEmail"  value="noreply@aivirtrix.com"/>
  <add key="SmtpFromName"   value="Aivirtrix"/>
  <add key="ContactEmail"   value="info@aivirtrix.com"/>
  <add key="SupportEmail"   value="support@aivirtrix.com"/>

  <!-- ── Google reCAPTCHA v3 (optional) ── -->
  <add key="EnableRecaptcha"    value="false"/>
  <add key="RecaptchaSiteKey"   value="REPLACE_WITH_SITE_KEY"/>
  <add key="RecaptchaSecretKey" value="REPLACE_WITH_SECRET_KEY"/>

  <!-- ── Google Analytics ── -->
  <add key="GoogleAnalyticsId"  value="G-XXXXXXXXXX"/>

  <!-- ── Site Flags ── -->
  <add key="MaintenanceMode"    value="false"/>
  <add key="FormSpamProtection" value="true"/>

</appSettings>
